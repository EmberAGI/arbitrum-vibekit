{
  "name": "langgraph-js-starter",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --dir ../.. exec turbo run dev --filter='./clients/web-ag-ui/apps/*'",
    "dev:delegations-bypass": "DELEGATIONS_BYPASS=true NEXT_PUBLIC_DELEGATIONS_BYPASS=true pnpm --dir ../.. exec turbo run dev --filter='./clients/web-ag-ui/apps/*'",
    "qa": "bash scripts/qa.sh",
    "build": "pnpm --dir ../.. exec turbo run build --filter='./clients/web-ag-ui/apps/*'",
    "qa:web": "pnpm build && pnpm start",
    "start": "pnpm --dir ../.. exec turbo run start --filter='./clients/web-ag-ui/apps/*'",
    "start:delegations-bypass": "DELEGATIONS_BYPASS=true NEXT_PUBLIC_DELEGATIONS_BYPASS=true pnpm --dir ../.. exec turbo run start --filter='./clients/web-ag-ui/apps/*'",
    "lint": "pnpm --dir ../.. exec turbo run lint --filter='./clients/web-ag-ui/apps/*'",
    "test": "pnpm -r --filter \"./apps/*\" run test",
    "test:unit": "pnpm -r --filter \"./apps/*\" run test:unit",
    "test:int": "pnpm -r --filter \"./apps/*\" run test:int",
    "test:e2e": "pnpm -r --filter \"./apps/*\" run test:e2e",
    "test:watch": "pnpm -r --parallel --filter \"./apps/*\" run test:watch",
    "test:ci": "pnpm -r --filter \"./apps/*\" run test:ci",
    "reset:dev-stack": "bash scripts/reset-dev-stack.sh"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.0.4",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.8",
    "next": "16.0.8"
  },
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "@langchain/core": "^1.0.1",
    "@langchain/langgraph": "1.0.2"
  }
}
