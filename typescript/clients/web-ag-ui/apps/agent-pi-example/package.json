{
  "name": "agent-pi-example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "types": "src/server.ts",
  "exports": {
    ".": "./src/server.ts",
    "./ag-ui-server": "./src/agUiServer.ts"
  },
  "scripts": {
    "build:runtime-deps": "pnpm --dir ../../../.. --filter agent-runtime build",
    "dev": "tsx src/server.ts",
    "predev": "pnpm build:runtime-deps",
    "prebuild": "pnpm build:runtime-deps",
    "prestart": "pnpm build:runtime-deps",
    "pretest:unit": "pnpm build:runtime-deps",
    "start": "tsx src/server.ts",
    "build": "tsc --project tsconfig.json",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:ci": "pnpm test:unit"
  },
  "dependencies": {
    "agent-runtime": "workspace:^"
  },
  "dependenciesMeta": {
    "agent-runtime": {
      "injected": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.2",
    "tsx": "catalog:",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
