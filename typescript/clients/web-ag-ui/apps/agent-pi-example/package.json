{
  "name": "agent-pi-example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "types": "src/server.ts",
  "files": [
    "src",
    "dist",
    "README.md",
    ".env.example",
    "tsconfig.json",
    "tests/setup"
  ],
  "exports": {
    ".": "./src/server.ts",
    "./ag-ui-server": "./src/agUiServer.ts"
  },
  "scripts": {
    "build:runtime-deps": "pnpm --dir ../../../.. --filter agent-runtime build",
    "dev": "bash -lc 'ENV_FILE=.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.example; exec node --env-file=\"$ENV_FILE\" ./node_modules/tsx/dist/cli.mjs src/server.ts \"$@\"' --",
    "prelint": "pnpm build:runtime-deps",
    "predev": "pnpm build:runtime-deps",
    "prebuild": "pnpm build:runtime-deps",
    "prestart": "pnpm build:runtime-deps",
    "pretest:int": "pnpm build:runtime-deps",
    "pretest:unit": "pnpm build:runtime-deps",
    "start": "bash -lc 'ENV_FILE=.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.example; exec node --env-file=\"$ENV_FILE\" ./node_modules/tsx/dist/cli.mjs src/server.ts \"$@\"' --",
    "build": "tsc --project tsconfig.json",
    "test": "pnpm test:unit && pnpm test:int",
    "test:int": "vitest run --config vitest.config.int.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:ci": "pnpm test:unit && pnpm test:int"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.62.0",
    "agent-runtime": "workspace:^"
  },
  "dependenciesMeta": {
    "agent-runtime": {
      "injected": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.2",
    "tsx": "catalog:",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
