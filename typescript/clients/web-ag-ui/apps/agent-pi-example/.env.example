# agent-pi-example (.env.example)
#
# Copy to `.env` (gitignored) to override locally. The `pnpm dev` and `pnpm start`
# scripts automatically load `.env`, falling back to this file when `.env` is absent.

# Required for the real Pi-native agent loop.
OPENROUTER_API_KEY=

# Optional: override the OpenRouter model id used by the Pi runtime gateway.
# Defaults to `openai/gpt-5.4-mini`.
# PI_AGENT_MODEL=openai/gpt-5.4-mini

# Optional: bind the HTTP server to a different port.
# PORT=3410

# Optional: use an existing Postgres instance instead of the shared local bootstrap.
# When omitted, the shared `agent-runtime` helper automatically ensures a local Docker
# Postgres container named `pi-runtime-postgres` is available at the default URL below.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/pi_runtime

# Optional test/dev-only external-boundary override.
# - mocked: keep the real Pi runtime + Postgres + transport stack, but replace the
#   external LLM boundary with a deterministic local stream.
# - live: default runtime behavior that calls OpenRouter.
# PI_AGENT_EXTERNAL_BOUNDARY_MODE=live
