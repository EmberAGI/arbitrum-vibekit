# syntax=docker/dockerfile:1.7
FROM node:22

WORKDIR /opt/ember-orchestration-v1-spec

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV PNPM_STORE_DIR="/pnpm/store"

RUN corepack enable && corepack prepare pnpm@10.0.0 --activate

COPY --from=shared_ember_spec . .

RUN --mount=type=cache,id=shared-ember-spec-pnpm-store,target=/pnpm/store pnpm install --frozen-lockfile

CMD ["sh", "-lc", "node ./node_modules/tsx/dist/cli.mjs ./scripts/shared-domain-service-http-reference-server.ts"]
