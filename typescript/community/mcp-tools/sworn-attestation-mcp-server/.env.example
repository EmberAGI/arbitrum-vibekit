# SWORN Protocol Relay URL
# Default: https://sworn-pact-relay.chitacloud.dev (public relay, no auth required)
# Override with your own relay if you want to self-host
SWORN_RELAY_URL=https://sworn-pact-relay.chitacloud.dev

# Transport mode: "http" (default, for remote deployment) or "stdio" (for Claude Desktop local use)
TRANSPORT_MODE=http

# Port for HTTP server (default: 3000)
PORT=3000