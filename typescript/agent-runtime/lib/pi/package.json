{
  "name": "agent-runtime-pi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pi-transport": {
      "types": "./src/piTransport.d.ts",
      "default": "./src/piTransport.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint \"src\" --ext .ts",
    "lint:fix": "eslint \"src\" --ext .ts --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --check",
    "test": "pnpm test:unit && pnpm test:int",
    "test:watch": "vitest watch --config vitest.config.unit.ts",
    "test:int": "vitest run --config vitest.config.int.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:ci": "pnpm test:unit && pnpm test:int"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.42",
    "@ag-ui/core": "0.0.42",
    "@mariozechner/pi-agent-core": "0.60.0",
    "@mariozechner/pi-ai": "0.60.0",
    "agent-runtime-contracts": "workspace:^",
    "agent-runtime-postgres": "workspace:^"
  }
}
