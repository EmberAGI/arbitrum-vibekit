{
  "name": "agent-runtime-pi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pi-transport": {
      "types": "./dist/piTransport.d.ts",
      "default": "./dist/piTransport.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --dir ../../.. --filter agent-runtime-postgres build",
    "build": "tsc --project tsconfig.json",
    "lint": "eslint \"src\" --ext .ts",
    "lint:fix": "eslint \"src\" --ext .ts --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --check",
    "prelint": "pnpm build:deps",
    "prebuild": "pnpm build:deps",
    "pretest:int": "pnpm build:deps",
    "pretest:unit": "pnpm build:deps",
    "test": "pnpm test:unit && pnpm test:int",
    "test:watch": "vitest watch --config vitest.config.unit.ts",
    "test:int": "vitest run --config vitest.config.int.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:ci": "pnpm test:unit && pnpm test:int"
  },
  "dependenciesMeta": {
    "agent-runtime-postgres": {
      "injected": false
    }
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@ag-ui/client": "0.0.48",
    "@ag-ui/core": "0.0.48",
    "@mariozechner/pi-agent-core": "0.64.0",
    "@mariozechner/pi-ai": "0.64.0",
    "agent-runtime-postgres": "workspace:^",
    "fast-json-patch": "3.1.1"
  },
  "devDependencies": {
    "rxjs": "7.8.1"
  }
}
