{
  "name": "agent-runtime",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --dir .. --filter agent-runtime-contracts --filter agent-runtime-pi build",
    "build": "tsc --project tsconfig.json && node ./scripts/sync-installed-artifacts.mjs",
    "lint": "eslint \"src\" --ext .ts",
    "lint:fix": "eslint \"src\" --ext .ts --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --check",
    "prelint": "pnpm build:deps",
    "prebuild": "pnpm build:deps",
    "pretest:int": "pnpm build:deps",
    "pretest:unit": "pnpm build:deps",
    "test": "pnpm test:unit && pnpm test:int",
    "test:int": "vitest run --config vitest.config.int.ts",
    "test:watch": "vitest watch --config vitest.config.unit.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:ci": "pnpm test:unit && pnpm test:int"
  },
  "devDependencies": {
    "@types/node": "^22.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependenciesMeta": {
    "agent-runtime-contracts": {
      "injected": false
    },
    "agent-runtime-pi": {
      "injected": false
    }
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.62.0",
    "agent-runtime-contracts": "workspace:^",
    "agent-runtime-pi": "workspace:^"
  }
}
