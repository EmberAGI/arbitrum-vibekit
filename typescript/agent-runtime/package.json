{
  "name": "agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "lib/contracts/dist",
    "lib/pi/dist",
    "lib/postgres/dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pi-transport": {
      "types": "./dist/piTransport.d.ts",
      "default": "./dist/piTransport.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --dir .. --filter agent-runtime-contracts --filter agent-runtime-pi build",
    "build": "tsc --project tsconfig.json && node ./scripts/sync-installed-artifacts.mjs",
    "lint": "eslint \"src\" --ext .ts",
    "lint:fix": "eslint \"src\" --ext .ts --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --check",
    "prelint": "pnpm build:deps",
    "prebuild": "pnpm build:deps",
    "pretest:unit": "pnpm build:deps",
    "test": "pnpm test:unit",
    "test:watch": "vitest watch --config vitest.config.unit.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:ci": "pnpm test:unit"
  },
  "devDependencies": {
    "@types/node": "^22.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.4",
    "@ag-ui/client": "0.0.47",
    "@ag-ui/core": "0.0.47",
    "@mariozechner/pi-agent-core": "0.62.0",
    "@mariozechner/pi-ai": "0.62.0",
    "pg": "^8.20.0"
  }
}
