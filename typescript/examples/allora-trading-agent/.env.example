# This file contains secrets and service locations for the agent.

# --- Required for Agent Operation ---
# Your API key for the OpenRouter service, used for LLM capabilities.
OPENROUTER_API_KEY=
#ALLORA_API_KEY=
# --- Required for Tool Connections ---
# The full SSE URL for the running Allora Price Prediction Agent.
ALLORA_AGENT_URL=http://localhost:3008/sse
# The gRPC endpoint for the Ember AI service. This is used by the underlying ember-mcp-tool-server.
EMBER_ENDPOINT=grpc.api.emberai.xyz:50051